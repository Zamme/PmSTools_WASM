@page "/find-address"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject AddressParser Parser
@inject GeocodingService Geocoder
@inject PlaceStorage Storage
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop

<section class="hero">
    <div>
        <h1>Find Address</h1>
        <p>Scan or upload an address label, review the parsed fields, and open it on a map.</p>
        <div class="hero-cta">
            <button class="btn-primary icon-button" @onclick="StartCameraAsync" disabled="@IsBusy" aria-label="Start camera" title="Start camera">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M7 7h10a3 3 0 0 1 3 3v7a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-7a3 3 0 0 1 3-3zm2-3h6l2 2h-10l2-2z" />
                    <circle cx="12" cy="13" r="3.25" />
                </svg>
            </button>
            <button class="btn-secondary icon-button" @onclick="CaptureFromCameraAsync" disabled="@(!IsCameraOn || IsBusy)" aria-label="Capture and read" title="Capture and read">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <circle cx="12" cy="12" r="6.5" />
                </svg>
            </button>
            <button class="btn-ghost icon-button" @onclick="StopCameraAsync" disabled="@(!IsCameraOn)" aria-label="Stop camera" title="Stop camera">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <rect x="7" y="7" width="10" height="10" rx="1.5" />
                </svg>
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="notice" style="margin-top: 12px;">@StatusMessage</div>
        }
    </div>
    <div class="camera-box">
        <div style="display: flex; gap: 16px; align-items: flex-start; flex-wrap: wrap;">
            <div style="flex: 1 1 240px; min-width: 220px;">
                <video id="addressCamera" playsinline muted></video>
                <div class="camera-status">@CameraStatus</div>
            </div>
            <div style="flex: 1 1 240px; min-width: 220px;">
                @if (!string.IsNullOrWhiteSpace(LastImageDataUrl))
                {
                    <div class="notice preview-selection-card">
                        <strong>Preview:</strong>
                        <span class="badge" style="margin-left:8px;">@PreviewSourceLabel</span>
                        <div class="preview-crop-shell @(LastImageComesFromFile ? string.Empty : "camera-preview-mode")" @ref="PreviewCropShell">
                            <img src="@LastImageDataUrl" alt="Captured or uploaded label" class="preview-crop-image" />
                            @if (LastImageComesFromFile)
                            {
                                <div class="preview-crop-overlay" aria-hidden="true">
                                    <div class="preview-crop-box" style="@PreviewCropStyle"></div>
                                </div>
                            }
                        </div>
                        @if (LastImageComesFromFile)
                        {
                            <p class="preview-crop-hint">Drag on the image to mark the approximate code area, then re-run OCR on that region.</p>
                        }
                        else
                        {
                            <p class="preview-crop-hint">Camera captures are always processed using the full image.</p>
                        }
                        <div class="crop-controls">
                            @if (LastImageComesFromFile)
                            {
                                <p class="crop-summary">Area: left @FormatPercent(CropLeftPercent), top @FormatPercent(CropTopPercent), width @FormatPercent(CropWidthPercent), height @FormatPercent(CropHeightPercent)</p>
                            }
                            <div class="crop-actions">
                                @if (LastImageComesFromFile)
                                {
                                    <button class="btn-secondary" @onclick="ReadSelectedAreaAsync" disabled="@IsBusy">Read selected area</button>
                                }
                                <button class="btn-ghost" @onclick="ReadFullImageAsync" disabled="@IsBusy">Read full image</button>
                                @if (LastImageComesFromFile)
                                {
                                    <button class="btn-ghost" @onclick="ResetCropSelection" disabled="@IsBusy">Reset area</button>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="notice">No capture yet.</div>
                }
            </div>
        </div>
    </div>
</section>

<div class="panel-grid" style="margin-top: 24px;">
    <div class="panel">
        <div class="panel-header">
            <h2>OCR input</h2>
            <div class="panel-header-actions">
                <span class="badge">Camera or file</span>
                <button class="btn-ghost panel-toggle" @onclick="() => ShowOcrPanel = !ShowOcrPanel" aria-expanded="@ShowOcrPanel" aria-controls="ocr-panel-body" title="Toggle OCR input">
                    <svg class="chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M6.7 9.2 12 14.5l5.3-5.3 1.4 1.4-6.7 6.7-6.7-6.7z" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="panel-body" id="ocr-panel-body" hidden="@(!ShowOcrPanel)">
            <p>Upload a photo if the camera is unavailable. We will run OCR in-browser.</p>
            <div class="stack">
                <InputFile OnChange="HandleFileSelected" accept="image/*" />
                @if (IsBusy)
                {
                    <div class="loading" aria-live="polite">
                        <span></span><span></span><span></span>
                        Reading text...
                    </div>
                }
                <textarea class="ocr-preview" placeholder="OCR text will appear here" @bind="OcrText"></textarea>
                <button class="btn-ghost" @onclick="ParseFromOcrAsync" disabled="@IsBusy">Parse address from text</button>
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-header">
            <h2>Parsed address</h2>
            <span class="badge">Editable</span>
        </div>
        <p>Adjust the fields before searching. Searches use OpenStreetMap Nominatim.</p>
        <div class="address-grid">
            <label>
                <span>Name</span>
                <input @bind="CurrentPlace.Name" @onblur="PersistCurrentPlaceAsync" />
            </label>
            <label>
                <span>Street name</span>
                <input @bind="CurrentPlace.StreetName" @onblur="PersistCurrentPlaceAsync" />
            </label>
            <label>
                <span>Street number</span>
                <input @bind="CurrentPlace.StreetNumber" @onblur="PersistCurrentPlaceAsync" />
            </label>
            <label>
                <span>Postal code</span>
                <input @bind="CurrentPlace.PostalCode" @onblur="PersistCurrentPlaceAsync" />
            </label>
            <label>
                <span>City</span>
                <input @bind="CurrentPlace.City" @onblur="PersistCurrentPlaceAsync" />
            </label>
            <label>
                <span>Country</span>
                <input @bind="CurrentPlace.Country" @onblur="PersistCurrentPlaceAsync" />
            </label>
        </div>
        <div class="hero-cta" style="margin-top: 14px;">
            <button class="btn-primary" @onclick="SearchAsync" disabled="@IsBusy">Search address</button>
            <button class="btn-ghost" @onclick="SaveCurrentPlaceAsync" disabled="@IsBusy">Save to history</button>
        </div>
    </div>
</div>

<div class="panel-grid" style="margin-top: 24px;">
    <div class="panel">
        <div class="panel-header">
            <h2>Map candidates</h2>
            <span class="badge">@Candidates.Count found</span>
        </div>
        <p>Select a candidate to preview it on the map and save it.</p>

        @if (Candidates.Count == 0)
        {
            <div class="notice">No candidates yet. Run a search to fetch map results.</div>
        }
        else
        {
            <div class="candidate-list">
                @foreach (var candidate in Candidates)
                {
                    var isActive = SelectedCandidate == candidate;
                    <div class="candidate-card @(isActive ? "active" : string.Empty)">
                        <div>
                            <div class="candidate-title">@candidate.BuildShortLabel()</div>
                            <div class="muted">@candidate.DisplayName</div>
                        </div>
                        <div class="code-actions">
                            <button class="btn-ghost" @onclick="() => SelectCandidate(candidate)">Preview</button>
                            <a class="btn-secondary" href="@BuildMapLink(candidate)" target="_blank" rel="noopener">Open map</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="panel">
        <div class="panel-header">
            <h2>Map preview</h2>
            <span class="badge">OpenStreetMap</span>
        </div>
        <p>Preview the selected candidate on a static map.</p>

        @if (SelectedCandidate == null)
        {
            <div class="notice">Select a candidate to show the preview map.</div>
        }
        else
        {
            <div class="map-preview">
                <iframe title="Map preview" src="@BuildMapEmbed(SelectedCandidate)" loading="lazy"></iframe>
            </div>
        }
    </div>
</div>

<div class="panel" style="margin-top: 24px;">
    <div class="panel-header">
        <h2>Recent searches</h2>
        <div class="panel-header-actions">
            <span class="badge">@RecentPlaces.Count</span>
            <button class="btn-ghost panel-toggle" @onclick="() => ShowRecentPanel = !ShowRecentPanel" aria-expanded="@ShowRecentPanel" aria-controls="recent-panel-body" title="Toggle recent searches">
                <svg class="chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M6.7 9.2 12 14.5l5.3-5.3 1.4 1.4-6.7 6.7-6.7-6.7z" />
                </svg>
            </button>
        </div>
    </div>
    <div class="panel-body" id="recent-panel-body" hidden="@(!ShowRecentPanel)">
        <p>Quickly reuse recent addresses without scanning again.</p>

        @if (RecentPlaces.Count == 0)
        {
            <div class="notice">No saved places yet.</div>
        }
        else
        {
            <div class="candidate-list">
                @foreach (var place in RecentPlaces)
                {
                    <div class="candidate-card">
                        <div>
                            <div class="candidate-title">@place.BuildDisplayName()</div>
                        </div>
                        <div class="code-actions">
                            <button class="btn-ghost" @onclick="() => LoadPlace(place)">Use</button>
                            <button class="btn-ghost" @onclick="() => RemoveRecentPlace(place)">Remove</button>
                        </div>
                    </div>
                }
            </div>
            <div style="margin-top: 12px;">
                <button class="btn-ghost" @onclick="ClearRecentPlaces">Clear history</button>
            </div>
        }
    </div>
</div>

@code {
    private PlaceInfoItem CurrentPlace { get; set; } = new();
    private List<GeocodeCandidate> Candidates { get; set; } = new();
    private GeocodeCandidate? SelectedCandidate { get; set; }
    private List<PlaceInfoItem> RecentPlaces { get; set; } = new();
    private string? OcrText { get; set; }
    private string? StatusMessage { get; set; }
    private string? LastImageDataUrl { get; set; }
    private bool IsBusy { get; set; }
    private bool IsCameraOn { get; set; }
    private bool LastImageComesFromFile { get; set; }
    private bool LastImageUsesPreprocess { get; set; }
    private ElementReference PreviewCropShell { get; set; }
    private DotNetObjectReference<FindAddress>? _dotNetReference;
    private bool _cropSelectorNeedsSync;
    private bool ShowOcrPanel { get; set; }
    private bool ShowRecentPanel { get; set; }
    private double _cropLeftPercent = 18;
    private double _cropTopPercent = 38;
    private double _cropWidthPercent = 64;
    private double _cropHeightPercent = 18;

    private string CameraStatus => IsCameraOn ? "Camera live" : "Camera off";
    private string PreviewCropStyle => $"left:{CropLeftPercent:F2}%;top:{CropTopPercent:F2}%;width:{CropWidthPercent:F2}%;height:{CropHeightPercent:F2}%;";
    private string PreviewSourceLabel => LastImageComesFromFile ? "Source: File (bbox OCR)" : "Source: Camera (full OCR)";
    private double CropLeftPercent => _cropLeftPercent;
    private double CropTopPercent => _cropTopPercent;
    private double CropWidthPercent => _cropWidthPercent;
    private double CropHeightPercent => _cropHeightPercent;

    protected override async Task OnInitializedAsync()
    {
        RecentPlaces = await Storage.GetRecentPlacesAsync();
        var lastPlace = await Storage.GetLastPlaceAsync();
        if (lastPlace != null)
        {
            CurrentPlace = lastPlace;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_cropSelectorNeedsSync)
        {
            _cropSelectorNeedsSync = false;
            _dotNetReference ??= DotNetObjectReference.Create(this);

            if (!string.IsNullOrWhiteSpace(LastImageDataUrl) && LastImageComesFromFile)
            {
                await JS.InvokeVoidAsync("pmstools.setupCropSelection", PreviewCropShell, _dotNetReference);
            }
            else
            {
                await JS.InvokeVoidAsync("pmstools.destroyCropSelection", PreviewCropShell);
            }
        }
    }

    private async Task StartCameraAsync()
    {
        StatusMessage = null;
        IsBusy = true;
        try
        {
            var started = await JS.InvokeAsync<bool>("pmstools.startCamera", "addressCamera");
            IsCameraOn = started;
            StatusMessage = started ? "Camera ready. Aim at the label." : "Camera not available in this browser.";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Camera error: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task StopCameraAsync()
    {
        await JS.InvokeVoidAsync("pmstools.stopCamera", "addressCamera");
        IsCameraOn = false;
        StatusMessage = "Camera stopped.";
    }

    private async Task CaptureFromCameraAsync()
    {
        if (!IsCameraOn)
        {
            StatusMessage = "Start the camera first.";
            return;
        }

        await RunOcrAsync(async () =>
        {
            var dataUrl = await JS.InvokeAsync<string?>("pmstools.captureFrameDataUrl", "addressCamera");
            if (string.IsNullOrWhiteSpace(dataUrl))
            {
                throw new InvalidOperationException("Unable to capture frame.");
            }

            await JS.InvokeVoidAsync("pmstools.stopCamera", "addressCamera");
            IsCameraOn = false;

            LastImageDataUrl = dataUrl;
            LastImageComesFromFile = false;
            LastImageUsesPreprocess = true;
            ResetCropSelection();
            _cropSelectorNeedsSync = true;
            return await ReadImageAsync(dataUrl, preprocess: true, useSelectedArea: false);
        });
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file == null)
        {
            return;
        }

        await RunOcrAsync(async () =>
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 6 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var dataUrl = $"data:{file.ContentType};base64,{base64}";

            LastImageDataUrl = dataUrl;
            LastImageComesFromFile = true;
            LastImageUsesPreprocess = true;
            ResetCropSelection();
            _cropSelectorNeedsSync = true;
            return await ReadImageAsync(dataUrl, preprocess: true, useSelectedArea: false);
        });
    }

    [JSInvokable]
    public Task UpdateCropSelectionFromJs(double left, double top, double width, double height)
    {
        ApplyCropSelection(left * 100d, top * 100d, width * 100d, height * 100d);
        return InvokeAsync(StateHasChanged);
    }

    private async Task ReadSelectedAreaAsync()
    {
        if (string.IsNullOrWhiteSpace(LastImageDataUrl))
        {
            StatusMessage = "Capture or upload an image first.";
            return;
        }

        if (!LastImageComesFromFile)
        {
            StatusMessage = "Selected-area OCR is available only for uploaded files.";
            return;
        }

        await RunOcrAsync(() => ReadImageAsync(LastImageDataUrl, LastImageUsesPreprocess, useSelectedArea: true));
    }

    private async Task ReadFullImageAsync()
    {
        if (string.IsNullOrWhiteSpace(LastImageDataUrl))
        {
            StatusMessage = "Capture or upload an image first.";
            return;
        }

        await RunOcrAsync(() => ReadImageAsync(LastImageDataUrl, LastImageUsesPreprocess, useSelectedArea: false));
    }

    private async Task<string> ReadImageAsync(string dataUrl, bool preprocess, bool useSelectedArea)
    {
        var effectiveUseSelectedArea = useSelectedArea && LastImageComesFromFile;

        var selectedText = await JS.InvokeAsync<string>("pmstools.ocrFromDataUrl", dataUrl, BuildOcrOptions(preprocess, effectiveUseSelectedArea));
        if (effectiveUseSelectedArea && string.IsNullOrWhiteSpace(selectedText))
        {
            return await JS.InvokeAsync<string>("pmstools.ocrFromDataUrl", dataUrl, BuildOcrOptions(preprocess, useSelectedArea: false));
        }

        return selectedText;
    }

    private Dictionary<string, object?> BuildOcrOptions(bool preprocess, bool useSelectedArea)
    {
        var options = new Dictionary<string, object?>
        {
            ["preprocess"] = preprocess,
            ["whitelist"] = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789",
            ["lang"] = "eng",
            ["psm"] = 11,
            ["dpi"] = 300
        };

        if (preprocess)
        {
            options["maxDim"] = 1600;
            options["adaptiveThreshold"] = true;
            options["adaptiveBlockSize"] = 31;
            options["adaptiveC"] = 7;
            options["denoiseKernelSize"] = 3;
            options["closeKernelSize"] = 2;
            options["threshold"] = 165;
            options["contrast"] = 1.2;
        }

        if (useSelectedArea)
        {
            options["crop"] = new Dictionary<string, object?>
            {
                ["mode"] = "normalized",
                ["x"] = CropLeftPercent / 100d,
                ["y"] = CropTopPercent / 100d,
                ["width"] = CropWidthPercent / 100d,
                ["height"] = CropHeightPercent / 100d
            };
        }

        return options;
    }

    private void ResetCropSelection()
    {
        ApplyCropSelection(18d, 38d, 64d, 18d);
    }

    private void ApplyCropSelection(double left, double top, double width, double height)
    {
        var normalizedLeft = Math.Clamp(left, 0d, 95d);
        var normalizedTop = Math.Clamp(top, 0d, 95d);
        var normalizedWidth = Math.Clamp(width, 0.1d, 100d - normalizedLeft);
        var normalizedHeight = Math.Clamp(height, 0.1d, 100d - normalizedTop);

        _cropLeftPercent = normalizedLeft;
        _cropTopPercent = normalizedTop;
        _cropWidthPercent = normalizedWidth;
        _cropHeightPercent = normalizedHeight;
    }

    private static string FormatPercent(double value)
    {
        return $"{value:F0}%";
    }

    private async Task RunOcrAsync(Func<Task<string>> ocrOperation)
    {
        IsBusy = true;
        StatusMessage = "Reading text...";

        try
        {
            var text = await ocrOperation();
            OcrText = Parser.NormalizeReadText(text);
            await ParseFromOcrAsync();
            StatusMessage = "OCR completed.";
        }
        catch (Exception ex)
        {
            StatusMessage = $"OCR failed: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task ParseFromOcrAsync()
    {
        CurrentPlace = Parser.Parse(OcrText);
        if (string.IsNullOrWhiteSpace(CurrentPlace.Country))
        {
            CurrentPlace.Country = "Spain";
        }

        await SearchAsync();
    }

    private async Task SearchAsync()
    {
        IsBusy = true;
        StatusMessage = "Searching map...";

        try
        {
            Candidates = await Geocoder.SearchAsync(CurrentPlace);
            SelectedCandidate = Candidates.FirstOrDefault();
            if (SelectedCandidate != null)
            {
                ApplyCandidate(SelectedCandidate);
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void SelectCandidate(GeocodeCandidate candidate)
    {
        SelectedCandidate = candidate;
        ApplyCandidate(candidate);
    }

    private void ApplyCandidate(GeocodeCandidate candidate)
    {
        CurrentPlace.StreetName = candidate.StreetName ?? CurrentPlace.StreetName;
        CurrentPlace.StreetNumber = candidate.StreetNumber ?? CurrentPlace.StreetNumber;
        CurrentPlace.PostalCode = candidate.PostalCode ?? CurrentPlace.PostalCode;
        CurrentPlace.City = candidate.City ?? CurrentPlace.City;
        CurrentPlace.Country = candidate.Country ?? CurrentPlace.Country;
        CurrentPlace.Latitude = candidate.Latitude;
        CurrentPlace.Longitude = candidate.Longitude;
    }

    private async Task SaveCurrentPlaceAsync()
    {
        await PersistCurrentPlaceAsync();
        StatusMessage = "Saved to history.";
    }

    private async Task PersistCurrentPlaceAsync()
    {
        if (!HasPlaceData(CurrentPlace))
        {
            return;
        }

        await Storage.SaveLastPlaceAsync(CurrentPlace);
        RecentPlaces = await Storage.GetRecentPlacesAsync();
    }

    private async Task LoadPlace(PlaceInfoItem place)
    {
        CurrentPlace = place;
        Candidates = new List<GeocodeCandidate>();
        SelectedCandidate = null;
        await PersistCurrentPlaceAsync();
    }

    private async Task RemoveRecentPlace(PlaceInfoItem place)
    {
        await Storage.RemoveRecentPlaceAsync(place);
        RecentPlaces = await Storage.GetRecentPlacesAsync();
    }

    private async Task ClearRecentPlaces()
    {
        await Storage.ClearRecentPlacesAsync();
        RecentPlaces = new List<PlaceInfoItem>();
    }

    private static string BuildMapEmbed(GeocodeCandidate candidate)
    {
        var lat = candidate.Latitude;
        var lon = candidate.Longitude;
        var latDelta = 0.006;
        var lonDelta = 0.01;
        var left = (lon - lonDelta).ToString(System.Globalization.CultureInfo.InvariantCulture);
        var right = (lon + lonDelta).ToString(System.Globalization.CultureInfo.InvariantCulture);
        var bottom = (lat - latDelta).ToString(System.Globalization.CultureInfo.InvariantCulture);
        var top = (lat + latDelta).ToString(System.Globalization.CultureInfo.InvariantCulture);
        var marker = $"{lat.ToString(System.Globalization.CultureInfo.InvariantCulture)},{lon.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
        return $"https://www.openstreetmap.org/export/embed.html?bbox={left}%2C{bottom}%2C{right}%2C{top}&layer=mapnik&marker={marker}";
    }

    private static string BuildMapLink(GeocodeCandidate candidate)
    {
        var lat = candidate.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var lon = candidate.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        return $"https://www.openstreetmap.org/?mlat={lat}&mlon={lon}#map=18/{lat}/{lon}";
    }

    private static bool HasPlaceData(PlaceInfoItem place)
    {
        return !(string.IsNullOrWhiteSpace(place.Name)
            && string.IsNullOrWhiteSpace(place.StreetName)
            && string.IsNullOrWhiteSpace(place.StreetNumber)
            && string.IsNullOrWhiteSpace(place.PostalCode)
            && string.IsNullOrWhiteSpace(place.City));
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("pmstools.destroyCropSelection", PreviewCropShell);

        if (IsCameraOn)
        {
            await JS.InvokeVoidAsync("pmstools.stopCamera", "addressCamera");
        }

        _dotNetReference?.Dispose();
    }
}
