@page "/"

<PageTitle>PmSTools</PageTitle>

<section class="hero">
	<div>
		<h1>Turn labels into barcodes and routes fast.</h1>
		<p>Scan codes, find addresses, and assemble routes in a single browser workspace.</p>
		<div class="hero-cta">
			<a class="btn-primary hero-cta-button" href="code2barcode" aria-label="Open Code to Barcode" title="Open Code to Barcode">
				<img src="images/code_to_barcode_01.png" alt="" aria-hidden="true" />
			</a>
			<a class="btn-secondary hero-cta-button" href="find-address" aria-label="Open Find Address" title="Open Find Address">
				<img src="images/find_place_01.png" alt="" aria-hidden="true" />
			</a>
			<a class="btn-ghost hero-cta-button hero-cta-route" href="create-route" aria-label="Open Create Route" title="Open Create Route">
				<img src="images/route_map_01.svg" alt="" aria-hidden="true" />
			</a>
		</div>
	</div>
	<div>
		<div class="panel">
			<h2>What is ready</h2>
			<p>Camera OCR, file upload OCR, prefix filtering, address lookup, and route editing are live for the web version.</p>
			<div class="stack">
				<div class="prefix-pill">
					<span class="prefix-value">OCR from camera</span>
					<span class="badge">Live</span>
				</div>
				<div class="prefix-pill">
					<span class="prefix-value">Address autosearch</span>
					<span class="badge">Live</span>
				</div>
				<div class="prefix-pill">
					<span class="prefix-value">Route builder</span>
					<span class="badge">Live</span>
				</div>
				<div class="prefix-pill">
					<span class="prefix-value">Prefix filters</span>
					<span class="badge">Live</span>
				</div>
				<div class="prefix-pill">
					<span class="prefix-value">Saved barcode library</span>
					<span class="badge">Live</span>
				</div>
			</div>
		</div>
	</div>
</section>
