@page "/"

<PageTitle>PmSTools</PageTitle>

<section class="hero">
	<div>
		<h1>Turn labels into barcodes fast.</h1>
		<p>Use your camera or upload a snapshot, filter by prefix, and keep a tidy library of saved barcodes.</p>
		<div class="hero-cta">
			<a class="btn-primary" href="code2barcode">Open Code to Barcode</a>
			<a class="btn-ghost" href="code2barcode">Review saved codes</a>
		</div>
	</div>
	<div>
		<div class="panel">
			<h2>What is ready</h2>
			<p>Camera OCR, file upload OCR, prefix filtering, and barcode export are live for the web version.</p>
			<div class="stack">
				<div class="prefix-pill">
					<span class="prefix-value">OCR from camera</span>
					<span class="badge">Live</span>
				</div>
				<div class="prefix-pill">
					<span class="prefix-value">Prefix filters</span>
					<span class="badge">Live</span>
				</div>
				<div class="prefix-pill">
					<span class="prefix-value">Saved barcode library</span>
					<span class="badge">Live</span>
				</div>
			</div>
		</div>
	</div>
</section>
