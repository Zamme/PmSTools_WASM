@page "/code2barcode"
@implements IAsyncDisposable
@inject BarcodeStorage Storage
@inject BarcodeParser Parser
@inject IJSRuntime JS
@using System.Globalization
@using Microsoft.JSInterop

<section class="hero">
    <div>
        <h1>Code to Barcode</h1>
        <p>Capture a label, extract codes, and print clean barcodes in one pass. Works with camera or file uploads.</p>
        <div class="hero-cta">
            <button class="btn-primary icon-button" @onclick="StartCameraAsync" disabled="@IsBusy" aria-label="Start camera" title="Start camera">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M7 7h10a3 3 0 0 1 3 3v7a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-7a3 3 0 0 1 3-3zm2-3h6l2 2h-10l2-2z" />
                    <circle cx="12" cy="13" r="3.25" />
                </svg>
            </button>
            <button class="btn-secondary icon-button" @onclick="CaptureFromCameraAsync" disabled="@(!IsCameraOn || IsBusy)" aria-label="Capture and read" title="Capture and read">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <circle cx="12" cy="12" r="6.5" />
                </svg>
            </button>
            <button class="btn-secondary icon-button" @onclick="ToggleBurstReadAsync" disabled="@(!IsCameraOn || (IsBusy && !IsBurstReading))" aria-label="@(IsBurstReading ? "Stop burst read" : "Burst read")" title="@(IsBurstReading ? "Stop burst read" : "Burst read (stability mode)")">
                @if (IsBurstReading)
                {
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <rect x="7" y="7" width="10" height="10" rx="1.5" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <circle cx="12" cy="12" r="3" />
                        <circle cx="12" cy="12" r="7" fill="none" stroke="currentColor" stroke-width="1.8" />
                        <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.4" stroke-dasharray="4 3" />
                    </svg>
                }
            </button>
            <button class="btn-ghost icon-button" @onclick="StopCameraAsync" disabled="@(!IsCameraOn)" aria-label="Stop camera" title="Stop camera">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <rect x="7" y="7" width="10" height="10" rx="1.5" />
                </svg>
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="notice" style="margin-top: 12px;">@StatusMessage</div>
        }
    </div>
    <div class="camera-box">
        <div style="display: flex; gap: 16px; align-items: flex-start; flex-wrap: wrap;">
            <div style="flex: 1 1 240px; min-width: 220px;">
                <div class="camera-stream-shell">
                    <video id="cameraStream" playsinline muted></video>
                    <div class="camera-guidance-overlay" aria-hidden="true">
                        <div class="camera-guidance-box" style="@CameraGuideStyle"></div>
                    </div>
                    <div class="camera-guidance-tip">Center the code inside the guide box before capture.</div>
                    <div class="camera-status">@CameraStatus</div>
                </div>
                <div class="camera-guide-controls">
                    <div class="panel-header-actions">
                        <p class="camera-guide-title">Guide box settings</p>
                        <button class="btn-ghost panel-toggle" @onclick="() => ShowCameraGuidePanel = !ShowCameraGuidePanel" aria-expanded="@ShowCameraGuidePanel" aria-controls="camera-guide-panel-body" title="Toggle guide box settings">
                            <svg class="chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M6.7 9.2 12 14.5l5.3-5.3 1.4 1.4-6.7 6.7-6.7-6.7z" />
                            </svg>
                        </button>
                    </div>
                    <div id="camera-guide-panel-body" hidden="@(!ShowCameraGuidePanel)">
                        <div class="camera-guide-presets">
                            <button class="btn-ghost" @onclick="ApplyCameraGuideNarrow" disabled="@IsBusy">Narrow</button>
                            <button class="btn-ghost" @onclick="ApplyCameraGuideStandard" disabled="@IsBusy">Standard</button>
                            <button class="btn-ghost" @onclick="ApplyCameraGuideWide" disabled="@IsBusy">Wide</button>
                        </div>
                        <div class="camera-guide-grid">
                            <label>
                                Left @FormatPercent(CameraGuideRect.Left)
                                <input type="range" min="0" max="95" step="0.5" @bind="_cameraGuideLeftPercent" @bind:event="oninput" />
                            </label>
                            <label>
                                Top @FormatPercent(CameraGuideRect.Top)
                                <input type="range" min="0" max="95" step="0.5" @bind="_cameraGuideTopPercent" @bind:event="oninput" />
                            </label>
                            <label>
                                Width @FormatPercent(CameraGuideRect.Width)
                                <input type="range" min="5" max="100" step="0.5" @bind="_cameraGuideWidthPercent" @bind:event="oninput" />
                            </label>
                            <label>
                                Height @FormatPercent(CameraGuideRect.Height)
                                <input type="range" min="5" max="100" step="0.5" @bind="_cameraGuideHeightPercent" @bind:event="oninput" />
                            </label>
                        </div>
                        <button class="btn-ghost" @onclick="ResetCameraGuideBox" disabled="@IsBusy">Reset guide box</button>
                    </div>
                </div>
            </div>
            <div style="flex: 1 1 240px; min-width: 220px;">
                @if (!string.IsNullOrWhiteSpace(LastImageDataUrl))
                {
                    <div class="notice preview-selection-card">
                        <strong>Preview:</strong>
                        <span class="badge" style="margin-left:8px;">@PreviewSourceLabel</span>
                        <div class="preview-crop-shell @(LastImageComesFromFile ? string.Empty : "camera-preview-mode")" @ref="PreviewCropShell">
                            <img src="@LastImageDataUrl" alt="Captured or uploaded label" class="preview-crop-image" />
                            @if (LastImageComesFromFile)
                            {
                                <div class="preview-crop-overlay" aria-hidden="true">
                                    <div class="preview-crop-box" style="@PreviewCropStyle"></div>
                                </div>
                            }
                        </div>
                        @if (LastImageComesFromFile)
                        {
                            <p class="preview-crop-hint">Drag on the image to mark the approximate code area, then re-run OCR on that region.</p>
                        }
                        else
                        {
                            <p class="preview-crop-hint">Camera captures are processed using the guide-box crop area.</p>
                        }
                        <div class="crop-controls">
                            @if (LastImageComesFromFile)
                            {
                                <p class="crop-summary">Area: left @FormatPercent(CropLeftPercent), top @FormatPercent(CropTopPercent), width @FormatPercent(CropWidthPercent), height @FormatPercent(CropHeightPercent)</p>
                            }
                            <div class="crop-actions">
                                @if (LastImageComesFromFile)
                                {
                                    <button class="btn-secondary" @onclick="ReadSelectedAreaAsync" disabled="@IsBusy">Read selected area</button>
                                }
                                <button class="btn-ghost" @onclick="ReadFullImageAsync" disabled="@IsBusy">Read full image</button>
                                @if (LastImageComesFromFile)
                                {
                                    <button class="btn-ghost" @onclick="ResetCropSelection" disabled="@IsBusy">Reset area</button>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="notice">No capture yet.</div>
                }
            </div>
        </div>
    </div>
</section>

<div class="panel" style="margin-top: 24px;">
    <div class="panel-header">
        <h2>Last codes</h2>
        <span class="badge">@LastCodes.Count found</span>
    </div>
    <p>These are the codes extracted from the most recent OCR run.</p>

    @if (LastCodes.Count == 0)
    {
        <div class="notice">No codes parsed yet. Capture or upload a label to begin.</div>
    }
    else
    {
        <div class="code-list">
            @foreach (var entry in LastCodes)
            {
                <div class="code-card">
                    <div class="barcode-wrap">
                        <svg id="@($"barcode-{entry.Id}")"></svg>
                    </div>
                    <div class="code-card-header">
                        <div class="code-id">@entry.Code</div>
                        @if (entry.IsSaved)
                        {
                            <span class="status-pill">Saved</span>
                        }
                    </div>
                    @if (entry.IsEditing)
                    {
                        <div class="input-row">
                            <input @bind="entry.EditValue" />
                        </div>
                    }
                    <div class="code-actions">
                        @if (entry.IsEditing)
                        {
                            <button class="btn-primary" @onclick="() => ApplyEdit(entry)">Save edit</button>
                            <button class="btn-ghost" @onclick="() => CancelEdit(entry)">Cancel</button>
                        }
                        else
                        {
                            <button class="btn-ghost" @onclick="() => BeginEdit(entry)">Edit</button>
                        }
                        @if (!entry.IsSaved)
                        {
                            <button class="btn-secondary" @onclick="() => SaveCode(entry)">Save code</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="panel-grid" style="margin-top: 24px;">
    <div class="panel">
        <div class="panel-header">
            <h2>OCR input</h2>
            <div class="panel-header-actions">
                <span class="badge">Image or camera</span>
                <button class="btn-ghost panel-toggle" @onclick="() => ShowOcrPanel = !ShowOcrPanel" aria-expanded="@ShowOcrPanel" aria-controls="ocr-panel-body" title="Toggle OCR input">
                    <svg class="chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M6.7 9.2 12 14.5l5.3-5.3 1.4 1.4-6.7 6.7-6.7-6.7z" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="panel-body" id="ocr-panel-body" hidden="@(!ShowOcrPanel)">
            <p>Upload a photo if the camera is unavailable. We will run OCR in-browser.</p>
            <div class="stack">
                <InputFile OnChange="HandleFileSelected" accept="image/*" />
                @if (IsBusy)
                {
                    <div class="loading" aria-live="polite">
                        <span></span><span></span><span></span>
                        Reading text...
                    </div>
                }
                <textarea class="ocr-preview" placeholder="OCR text will appear here" @bind="OcrText"></textarea>
                <textarea class="ocr-preview" placeholder="Cleaned OCR preview (A-Z, 0-9 only)" readonly>@CleanOcrPreview</textarea>
                <button class="btn-ghost" @onclick="RebuildFromOcrText" disabled="@IsBusy">Rebuild codes from text</button>
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-header">
            <h2>Manual code</h2>
            <div class="panel-header-actions">
                <span class="badge">Type and generate</span>
                <button class="btn-ghost panel-toggle" @onclick="() => ShowManualPanel = !ShowManualPanel" aria-expanded="@ShowManualPanel" aria-controls="manual-panel-body" title="Toggle manual code">
                    <svg class="chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M6.7 9.2 12 14.5l5.3-5.3 1.4 1.4-6.7 6.7-6.7-6.7z" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="panel-body" id="manual-panel-body" hidden="@(!ShowManualPanel)">
            <p>Type a code manually and generate a barcode instantly.</p>
            <div class="stack">
                <div class="input-row">
                    <input placeholder="Enter code" @bind="ManualCodeInput" @bind:event="oninput" />
                    <button class="btn-primary" @onclick="GenerateManualBarcode">Generate barcode</button>
                    <button class="btn-secondary" @onclick="AddManualCodeToLastAsync" disabled="@string.IsNullOrWhiteSpace(ManualBarcodeCode)">Add to last codes</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(ManualCodeMessage))
                {
                    <div class="notice">@ManualCodeMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(ManualBarcodeCode))
                {
                    <div class="code-card">
                        <div class="barcode-wrap">
                            <svg id="manual-barcode"></svg>
                        </div>
                        <div class="code-card-header">
                            <div class="code-id">@ManualBarcodeCode</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-header">
            <h2>Prefixes</h2>
            <div class="panel-header-actions">
                <span class="badge">Filtering</span>
                <button class="btn-ghost panel-toggle" @onclick="() => ShowPrefixesPanel = !ShowPrefixesPanel" aria-expanded="@ShowPrefixesPanel" aria-controls="prefixes-panel-body" title="Toggle prefixes">
                    <svg class="chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M6.7 9.2 12 14.5l5.3-5.3 1.4 1.4-6.7 6.7-6.7-6.7z" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="panel-body" id="prefixes-panel-body" hidden="@(!ShowPrefixesPanel)">
            <p>Only codes that begin with an enabled prefix are kept.</p>
            <div class="stack">
                @if (Prefixes.Count == 0)
                {
                    <div class="notice">No prefixes yet. Add at least one to enable extraction.</div>
                }
                else
                {
                    @foreach (var prefix in Prefixes)
                    {
                        <div class="prefix-pill">
                            <label>
                                <input type="checkbox" checked="@prefix.IsActive" @onchange="(args) => TogglePrefix(prefix, args)" />
                                <span class="prefix-value">@prefix.Value</span>
                            </label>
                            <button class="btn-ghost" @onclick="() => RemovePrefix(prefix)">Remove</button>
                        </div>
                    }
                }
                <div class="input-row">
                    <input placeholder="Add prefix" @bind="NewPrefix" />
                    <button class="btn-primary" @onclick="AddPrefix">Add</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="panel" style="margin-top: 24px;">
    <div class="panel-header">
        <h2>Saved codes</h2>
        <div class="panel-header-actions">
            <span class="badge">@SavedEntries.Count total</span>
            <button class="btn-ghost panel-toggle" @onclick="() => ShowSavedPanel = !ShowSavedPanel" aria-expanded="@ShowSavedPanel" aria-controls="saved-panel-body" title="Toggle saved codes">
                <svg class="chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M6.7 9.2 12 14.5l5.3-5.3 1.4 1.4-6.7 6.7-6.7-6.7z" />
                </svg>
            </button>
        </div>
    </div>
    <div class="panel-body" id="saved-panel-body" hidden="@(!ShowSavedPanel)">
        <p>These stay available in this browser, ready for reprint.</p>

        @if (SavedEntries.Count == 0)
        {
            <div class="notice">No saved codes yet.</div>
        }
        else
        {
            <div class="code-list">
                @foreach (var entry in SavedEntries)
                {
                    <div class="code-card">
                        <div class="barcode-wrap">
                            <svg id="@($"saved-{entry.Id}")"></svg>
                        </div>
                        <div class="code-card-header">
                            <div class="code-id">@entry.Code</div>
                            <span class="status-pill">Saved</span>
                        </div>
                        <div class="code-actions">
                            <button class="btn-ghost" @onclick="() => RemoveSavedCode(entry)">Remove</button>
                        </div>
                    </div>
                }
            </div>
            <div style="margin-top: 12px;">
                <button class="btn-ghost" @onclick="ClearSavedCodes">Clear all</button>
            </div>
        }
    </div>
</div>

@code {
    private List<PrefixItem> Prefixes { get; set; } = new();
    private List<BarcodeEntry> LastCodes { get; set; } = new();
    private List<BarcodeEntry> SavedEntries { get; set; } = new();
    private string? OcrText { get; set; }
    private string? StatusMessage { get; set; }
    private string? NewPrefix { get; set; }
    private string? ManualCodeInput { get; set; }
    private string? ManualBarcodeCode { get; set; }
    private string? ManualCodeMessage { get; set; }
    private string? LastImageDataUrl { get; set; }
    private bool IsBusy { get; set; }
    private bool IsCameraOn { get; set; }
    private bool LastImageComesFromFile { get; set; }
    private bool LastImageUsesPreprocess { get; set; }
    private bool IsBurstReading { get; set; }
    private ElementReference PreviewCropShell { get; set; }
    private DotNetObjectReference<Code2Barcode>? _dotNetReference;
    private CancellationTokenSource? _burstReadCts;
    private bool _cropSelectorNeedsSync;
    private bool _needsBarcodeRender;
    private bool ShowOcrPanel { get; set; }
    private bool ShowManualPanel { get; set; }
    private bool ShowPrefixesPanel { get; set; }
    private bool ShowSavedPanel { get; set; }
    private bool ShowCameraGuidePanel { get; set; }
    private double _cropLeftPercent = 18;
    private double _cropTopPercent = 38;
    private double _cropWidthPercent = 64;
    private double _cropHeightPercent = 18;
    private double _cameraGuideLeftPercent = 10;
    private double _cameraGuideTopPercent = 34;
    private double _cameraGuideWidthPercent = 80;
    private double _cameraGuideHeightPercent = 22;

    private string CameraStatus => IsCameraOn ? "Camera live" : "Camera off";
    private (double Left, double Top, double Width, double Height) CameraGuideRect
    {
        get
        {
            var left = Math.Clamp(_cameraGuideLeftPercent, 0d, 95d);
            var top = Math.Clamp(_cameraGuideTopPercent, 0d, 95d);
            var width = Math.Clamp(_cameraGuideWidthPercent, 0.1d, 100d - left);
            var height = Math.Clamp(_cameraGuideHeightPercent, 0.1d, 100d - top);
            return (left, top, width, height);
        }
    }
    private string CleanOcrPreview => string.Join(" ", Parser.ParseCodes(OcrText ?? string.Empty, Prefixes.Where(prefix => prefix.IsActive).Select(prefix => prefix.Value)));
    private string CameraGuideStyle => $"left:{ToCssPercent(CameraGuideRect.Left)}%;top:{ToCssPercent(CameraGuideRect.Top)}%;width:{ToCssPercent(CameraGuideRect.Width)}%;height:{ToCssPercent(CameraGuideRect.Height)}%;";
    private string PreviewCropStyle => $"left:{ToCssPercent(CropLeftPercent)}%;top:{ToCssPercent(CropTopPercent)}%;width:{ToCssPercent(CropWidthPercent)}%;height:{ToCssPercent(CropHeightPercent)}%;";
    private string PreviewSourceLabel => LastImageComesFromFile ? "Source: File (bbox OCR)" : "Source: Camera (guide-box crop OCR)";
    private double CropLeftPercent => _cropLeftPercent;
    private double CropTopPercent => _cropTopPercent;
    private double CropWidthPercent => _cropWidthPercent;
    private double CropHeightPercent => _cropHeightPercent;

    protected override async Task OnInitializedAsync()
    {
        Prefixes = await Storage.GetPrefixesAsync();
        var savedCodes = await Storage.GetSavedCodesAsync();
        var lastCodes = await Storage.GetLastCodesAsync();

        SavedEntries = BuildEntries(savedCodes, savedCodes);
        LastCodes = BuildEntries(lastCodes, savedCodes);
        _needsBarcodeRender = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsBarcodeRender)
        {
            _needsBarcodeRender = false;

            foreach (var entry in LastCodes)
            {
                await JS.InvokeVoidAsync("pmstools.renderBarcode", $"barcode-{entry.Id}", entry.Code);
            }

            foreach (var entry in SavedEntries)
            {
                await JS.InvokeVoidAsync("pmstools.renderBarcode", $"saved-{entry.Id}", entry.Code);
            }

            if (!string.IsNullOrWhiteSpace(ManualBarcodeCode))
            {
                await JS.InvokeVoidAsync("pmstools.renderBarcode", "manual-barcode", ManualBarcodeCode);
            }
        }

        if (_cropSelectorNeedsSync)
        {
            _cropSelectorNeedsSync = false;
            _dotNetReference ??= DotNetObjectReference.Create(this);

            if (!string.IsNullOrWhiteSpace(LastImageDataUrl) && LastImageComesFromFile)
            {
                await JS.InvokeVoidAsync("pmstools.setupCropSelection", PreviewCropShell, _dotNetReference);
            }
            else
            {
                await JS.InvokeVoidAsync("pmstools.destroyCropSelection", PreviewCropShell);
            }
        }
    }

    private async Task StartCameraAsync()
    {
        StatusMessage = null;
        IsBusy = true;
        try
        {
            var started = await JS.InvokeAsync<bool>("pmstools.startCamera", "cameraStream");
            IsCameraOn = started;
            StatusMessage = started ? "Camera ready. Center the code inside the guide box." : "Camera not available in this browser.";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Camera error: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task StopCameraAsync()
    {
        StopBurstRead();
        await JS.InvokeVoidAsync("pmstools.stopCamera", "cameraStream");
        IsCameraOn = false;
        StatusMessage = "Camera stopped.";
    }

    private Task ToggleBurstReadAsync()
    {
        if (IsBurstReading)
        {
            StopBurstRead();
            return Task.CompletedTask;
        }

        return BurstReadFromCameraAsync();
    }

    private void StopBurstRead()
    {
        if (!IsBurstReading)
        {
            return;
        }

        _burstReadCts?.Cancel();
        StatusMessage = "Stopping burst read...";
    }

    private async Task CaptureFromCameraAsync()
    {
        if (!IsCameraOn)
        {
            StatusMessage = "Start the camera first.";
            return;
        }

        await RunOcrAsync(async () =>
        {
            var dataUrl = await CaptureGuideFrameDataUrlAsync();
            if (string.IsNullOrWhiteSpace(dataUrl))
            {
                throw new InvalidOperationException("Unable to capture frame.");
            }

            await JS.InvokeVoidAsync("pmstools.stopCamera", "cameraStream");
            IsCameraOn = false;

            LastImageDataUrl = dataUrl;
            LastImageComesFromFile = false;
            LastImageUsesPreprocess = true;
            ResetCropSelection();
            _cropSelectorNeedsSync = true;
            return await ReadImageAsync(dataUrl, preprocess: true, useSelectedArea: false);
        });
    }

    private async Task BurstReadFromCameraAsync()
    {
        if (!IsCameraOn)
        {
            StatusMessage = "Start the camera first.";
            return;
        }

        if (IsBurstReading)
        {
            return;
        }

        const int requiredConsensus = 3;
        const int maxAttempts = 12;

        _burstReadCts = new CancellationTokenSource();
        var cancellationToken = _burstReadCts.Token;

        IsBusy = true;
        IsBurstReading = true;
        StatusMessage = "Burst reading started. Hold the camera still.";

        var lastSignature = string.Empty;
        var currentStreak = 0;
        string? finalText = null;
        string? finalDataUrl = null;

        try
        {
            for (var attempt = 1; attempt <= maxAttempts; attempt++)
            {
                cancellationToken.ThrowIfCancellationRequested();

                var isCameraRunning = await JS.InvokeAsync<bool>("pmstools.isCameraRunning", "cameraStream");
                if (!isCameraRunning)
                {
                    throw new OperationCanceledException("Camera is no longer running.", cancellationToken);
                }

                var dataUrl = await CaptureGuideFrameDataUrlAsync();
                if (string.IsNullOrWhiteSpace(dataUrl))
                {
                    continue;
                }

                var text = await ReadImageAsync(dataUrl, preprocess: true, useSelectedArea: false);
                var activePrefixes = Prefixes.Where(prefix => prefix.IsActive).Select(prefix => prefix.Value);
                var parsedCodes = Parser.ParseCodes(text ?? string.Empty, activePrefixes).ToList();
                var signature = parsedCodes.Count > 0 ? string.Join("|", parsedCodes) : string.Empty;

                if (!string.IsNullOrWhiteSpace(signature) && string.Equals(signature, lastSignature, StringComparison.OrdinalIgnoreCase))
                {
                    currentStreak++;
                }
                else if (!string.IsNullOrWhiteSpace(signature))
                {
                    lastSignature = signature;
                    currentStreak = 1;
                }
                else
                {
                    currentStreak = 0;
                }

                StatusMessage = currentStreak > 0
                    ? $"Burst read {attempt}/{maxAttempts}: stability {currentStreak}/{requiredConsensus}."
                    : $"Burst read {attempt}/{maxAttempts}: unstable, keep still.";
                await InvokeAsync(StateHasChanged);

                if (currentStreak >= requiredConsensus)
                {
                    finalText = text;
                    finalDataUrl = dataUrl;
                    await JS.InvokeVoidAsync("pmstools.stopCamera", "cameraStream");
                    IsCameraOn = false;
                    break;
                }

                // Start the next capture as soon as OCR for the current frame completes.
                await Task.Yield();
            }

            if (!string.IsNullOrWhiteSpace(finalText) && !string.IsNullOrWhiteSpace(finalDataUrl))
            {
                OcrText = finalText;
                LastImageDataUrl = finalDataUrl;
                LastImageComesFromFile = false;
                LastImageUsesPreprocess = true;
                ResetCropSelection();
                _cropSelectorNeedsSync = true;

                await RebuildFromOcrText();
                StatusMessage = "OCR completed with burst consensus.";
            }
            else
            {
                StatusMessage = "Unable to get a stable read. Keep the camera steady and try burst read again.";
            }
        }
        catch (OperationCanceledException)
        {
            StatusMessage = "Burst read stopped.";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Burst OCR failed: {ex.Message}";
        }
        finally
        {
            IsBurstReading = false;
            IsBusy = false;
            _burstReadCts?.Dispose();
            _burstReadCts = null;
        }
    }

    private async Task<string?> CaptureGuideFrameDataUrlAsync()
    {
        var guideRect = CameraGuideRect;
        return await JS.InvokeAsync<string?>("pmstools.captureFrameDataUrl", "cameraStream", new Dictionary<string, object?>
        {
            ["crop"] = new Dictionary<string, object?>
            {
                ["mode"] = "normalized",
                ["x"] = guideRect.Left / 100d,
                ["y"] = guideRect.Top / 100d,
                ["width"] = guideRect.Width / 100d,
                ["height"] = guideRect.Height / 100d
            }
        });
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file == null)
        {
            return;
        }

        await RunOcrAsync(async () =>
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 6 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var dataUrl = $"data:{file.ContentType};base64,{base64}";
            LastImageDataUrl = dataUrl;
            LastImageComesFromFile = true;
            LastImageUsesPreprocess = true;
            ResetCropSelection();
            _cropSelectorNeedsSync = true;
            return await ReadImageAsync(dataUrl, preprocess: true, useSelectedArea: false);
        });
    }

    [JSInvokable]
    public Task UpdateCropSelectionFromJs(double left, double top, double width, double height)
    {
        ApplyCropSelection(left * 100d, top * 100d, width * 100d, height * 100d);
        return InvokeAsync(StateHasChanged);
    }

    private async Task ReadSelectedAreaAsync()
    {
        if (string.IsNullOrWhiteSpace(LastImageDataUrl))
        {
            StatusMessage = "Capture or upload an image first.";
            return;
        }

        if (!LastImageComesFromFile)
        {
            StatusMessage = "Selected-area OCR is available only for uploaded files.";
            return;
        }

        await RunOcrAsync(() => ReadImageAsync(LastImageDataUrl, LastImageUsesPreprocess, useSelectedArea: true));
    }

    private async Task ReadFullImageAsync()
    {
        if (string.IsNullOrWhiteSpace(LastImageDataUrl))
        {
            StatusMessage = "Capture or upload an image first.";
            return;
        }

        await RunOcrAsync(() => ReadImageAsync(LastImageDataUrl, LastImageUsesPreprocess, useSelectedArea: false));
    }

    private async Task<string> ReadImageAsync(string dataUrl, bool preprocess, bool useSelectedArea)
    {
        var effectiveUseSelectedArea = useSelectedArea && LastImageComesFromFile;

        var selectedText = await JS.InvokeAsync<string>("pmstools.ocrFromDataUrl", dataUrl, BuildOcrOptions(preprocess, effectiveUseSelectedArea));
        if (effectiveUseSelectedArea && string.IsNullOrWhiteSpace(selectedText))
        {
            return await JS.InvokeAsync<string>("pmstools.ocrFromDataUrl", dataUrl, BuildOcrOptions(preprocess, useSelectedArea: false));
        }

        return selectedText;
    }

    private Dictionary<string, object?> BuildOcrOptions(bool preprocess, bool useSelectedArea)
    {
        var options = new Dictionary<string, object?>
        {
            ["preprocess"] = preprocess,
            ["whitelist"] = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789",
            ["lang"] = "eng",
            ["psm"] = 11,
            ["dpi"] = 300
        };

        if (preprocess)
        {
            options["maxDim"] = 1600;
            options["adaptiveThreshold"] = true;
            options["adaptiveBlockSize"] = 31;
            options["adaptiveC"] = 7;
            options["denoiseKernelSize"] = 3;
            options["closeKernelSize"] = 2;
            options["threshold"] = 165;
            options["contrast"] = 1.2;
        }

        if (useSelectedArea)
        {
            options["crop"] = new Dictionary<string, object?>
            {
                ["mode"] = "normalized",
                ["x"] = CropLeftPercent / 100d,
                ["y"] = CropTopPercent / 100d,
                ["width"] = CropWidthPercent / 100d,
                ["height"] = CropHeightPercent / 100d
            };
        }

        return options;
    }

    private void ResetCropSelection()
    {
        ApplyCropSelection(18d, 38d, 64d, 18d);
    }

    private void ResetCameraGuideBox()
    {
        _cameraGuideLeftPercent = 10d;
        _cameraGuideTopPercent = 34d;
        _cameraGuideWidthPercent = 80d;
        _cameraGuideHeightPercent = 22d;
    }

    private void ApplyCameraGuideNarrow()
    {
        SetCameraGuideBox(28d, 35d, 44d, 20d);
    }

    private void ApplyCameraGuideStandard()
    {
        SetCameraGuideBox(18d, 38d, 64d, 18d);
    }

    private void ApplyCameraGuideWide()
    {
        SetCameraGuideBox(10d, 34d, 80d, 22d);
    }

    private void SetCameraGuideBox(double left, double top, double width, double height)
    {
        _cameraGuideLeftPercent = left;
        _cameraGuideTopPercent = top;
        _cameraGuideWidthPercent = width;
        _cameraGuideHeightPercent = height;
    }

    private void ApplyCropSelection(double left, double top, double width, double height)
    {
        var normalizedLeft = Math.Clamp(left, 0d, 95d);
        var normalizedTop = Math.Clamp(top, 0d, 95d);
        var normalizedWidth = Math.Clamp(width, 0.1d, 100d - normalizedLeft);
        var normalizedHeight = Math.Clamp(height, 0.1d, 100d - normalizedTop);

        _cropLeftPercent = normalizedLeft;
        _cropTopPercent = normalizedTop;
        _cropWidthPercent = normalizedWidth;
        _cropHeightPercent = normalizedHeight;
    }

    private static string FormatPercent(double value)
    {
        return $"{value:F0}%";
    }

    private static string ToCssPercent(double value)
    {
        return value.ToString("F2", CultureInfo.InvariantCulture);
    }

    private async Task RunOcrAsync(Func<Task<string>> ocrOperation)
    {
        IsBusy = true;
        StatusMessage = "Reading text...";

        try
        {
            var text = await ocrOperation();
            OcrText = text;
            await RebuildFromOcrText();
            StatusMessage = "OCR completed.";
        }
        catch (Exception ex)
        {
            StatusMessage = $"OCR failed: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task RebuildFromOcrText()
    {
        var activePrefixes = Prefixes.Where(prefix => prefix.IsActive).Select(prefix => prefix.Value).ToList();
        var parsed = Parser.ParseCodes(OcrText ?? string.Empty, activePrefixes);
        var savedCodes = await Storage.GetSavedCodesAsync();

        LastCodes = BuildEntries(parsed, savedCodes);
        await Storage.SaveLastCodesAsync(parsed);
        _needsBarcodeRender = true;
        StateHasChanged();
    }

    private void GenerateManualBarcode()
    {
        var normalized = (ManualCodeInput ?? string.Empty).Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(normalized))
        {
            ManualBarcodeCode = null;
            ManualCodeMessage = "Type a code first.";
            return;
        }

        ManualCodeInput = normalized;
        ManualBarcodeCode = normalized;
        ManualCodeMessage = "Barcode generated.";
        _needsBarcodeRender = true;
    }

    private async Task AddManualCodeToLastAsync()
    {
        if (string.IsNullOrWhiteSpace(ManualBarcodeCode))
        {
            ManualCodeMessage = "Generate a barcode before adding.";
            return;
        }

        var code = ManualBarcodeCode;
        if (LastCodes.Any(entry => string.Equals(entry.Code, code, StringComparison.OrdinalIgnoreCase)))
        {
            ManualCodeMessage = "Code already exists in last codes.";
            return;
        }

        var savedCodes = await Storage.GetSavedCodesAsync();
        LastCodes.Insert(0, new BarcodeEntry(code, savedCodes.Contains(code, StringComparer.OrdinalIgnoreCase)));
        await Storage.SaveLastCodesAsync(LastCodes.Select(entry => entry.Code).ToList());

        ManualCodeMessage = "Code added to last codes.";
        _needsBarcodeRender = true;
    }

    private async Task TogglePrefix(PrefixItem prefix, ChangeEventArgs args)
    {
        prefix.IsActive = args?.Value switch
        {
            bool value => value,
            string text => string.Equals(text, "true", StringComparison.OrdinalIgnoreCase),
            _ => prefix.IsActive
        };
        await Storage.SavePrefixesAsync(Prefixes);
        await RebuildFromOcrText();
    }

    private async Task RemovePrefix(PrefixItem prefix)
    {
        Prefixes.Remove(prefix);
        await Storage.SavePrefixesAsync(Prefixes);
        await RebuildFromOcrText();
    }

    private async Task AddPrefix()
    {
        var value = (NewPrefix ?? string.Empty).Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        if (Prefixes.Any(prefix => string.Equals(prefix.Value, value, StringComparison.OrdinalIgnoreCase)))
        {
            NewPrefix = string.Empty;
            return;
        }

        Prefixes.Add(new PrefixItem(value, true));
        NewPrefix = string.Empty;
        await Storage.SavePrefixesAsync(Prefixes);
        await RebuildFromOcrText();
    }

    private async Task SaveCode(BarcodeEntry entry)
    {
        if (entry.IsSaved)
        {
            return;
        }

        var savedCodes = await Storage.GetSavedCodesAsync();
        savedCodes.Add(entry.Code.ToUpperInvariant());
        await Storage.SaveSavedCodesAsync(savedCodes);
        entry.IsSaved = true;
        RefreshSavedEntries(savedCodes);
    }

    private async Task RemoveSavedCode(BarcodeEntry entry)
    {
        var savedCodes = await Storage.GetSavedCodesAsync();
        savedCodes.RemoveAll(code => string.Equals(code, entry.Code, StringComparison.OrdinalIgnoreCase));
        await Storage.SaveSavedCodesAsync(savedCodes);
        RefreshSavedEntries(savedCodes);
        UpdateSavedStatusOnLastCodes(savedCodes);
    }

    private async Task ClearSavedCodes()
    {
        await Storage.SaveSavedCodesAsync(new List<string>());
        RefreshSavedEntries(new List<string>());
        UpdateSavedStatusOnLastCodes(new List<string>());
    }

    private void BeginEdit(BarcodeEntry entry)
    {
        entry.EditValue = entry.Code;
        entry.IsEditing = true;
    }

    private async Task ApplyEdit(BarcodeEntry entry)
    {
        var updated = (entry.EditValue ?? string.Empty).Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(updated))
        {
            entry.IsEditing = false;
            entry.EditValue = entry.Code;
            return;
        }

        var previous = entry.Code;
        entry.Code = updated;
        entry.EditValue = updated;
        entry.IsEditing = false;

        var codes = LastCodes.Select(item => item.Code).ToList();
        await Storage.SaveLastCodesAsync(codes);

        if (entry.IsSaved)
        {
            var savedCodes = await Storage.GetSavedCodesAsync();
            savedCodes.RemoveAll(code => string.Equals(code, previous, StringComparison.OrdinalIgnoreCase));
            savedCodes.Add(updated);
            await Storage.SaveSavedCodesAsync(savedCodes);
            RefreshSavedEntries(savedCodes);
            UpdateSavedStatusOnLastCodes(savedCodes);
        }

        _needsBarcodeRender = true;
    }

    private void CancelEdit(BarcodeEntry entry)
    {
        entry.IsEditing = false;
        entry.EditValue = entry.Code;
    }

    private void RefreshSavedEntries(List<string> savedCodes)
    {
        SavedEntries = BuildEntries(savedCodes, savedCodes);
        _needsBarcodeRender = true;
        StateHasChanged();
    }

    private void UpdateSavedStatusOnLastCodes(List<string> savedCodes)
    {
        var savedSet = new HashSet<string>(savedCodes, StringComparer.OrdinalIgnoreCase);
        foreach (var entry in LastCodes)
        {
            entry.IsSaved = savedSet.Contains(entry.Code);
        }
    }

    private static List<BarcodeEntry> BuildEntries(IEnumerable<string> codes, IEnumerable<string> savedCodes)
    {
        var savedSet = new HashSet<string>(savedCodes ?? Array.Empty<string>(), StringComparer.OrdinalIgnoreCase);
        return codes.Select(code => new BarcodeEntry(code, savedSet.Contains(code))).ToList();
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("pmstools.destroyCropSelection", PreviewCropShell);

        if (IsCameraOn)
        {
            await JS.InvokeVoidAsync("pmstools.stopCamera", "cameraStream");
        }

        _dotNetReference?.Dispose();
    }
}
